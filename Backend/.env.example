# Habilita trafico en tiempo real con Google Routes API.
# Activa "Routes API" en Google Cloud y pega una API key con permiso para routes.googleapis.com.
GOOGLE_MAPS_API_KEY=

# Dominios separados por coma que pueden llamar a la API.
# Ejemplo: https://tu-sitio.netlify.app,http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# En Render usa un disco persistente si quieres conservar favoritos/recientes.
# Ejemplo Render: /var/data/gps_data.sqlite3
SQLITE_DB_PATH=

# El servidor público de OSRM no admite exclude=toll/motorway.
# Para restricciones estrictas, usa Sakbé o configura una instancia OSRM propia
# cuyo perfil exponga esas clases y activa explícitamente el soporte.
OSRM_BASE_URL=https://router.project-osrm.org/route/v1/driving
OSRM_SUPPORTS_EXCLUSIONS=false
